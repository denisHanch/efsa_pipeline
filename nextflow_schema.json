{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/nextflow_schema.json",
  "title": "Automated Prokaryotic Genome Assembly Analysis Pipeline",
  "description": "Schema for pipeline parameters",
  "type": "object",

  "properties": {
    "in_dir": {
      "type": "string",
      "format": "directory",
      "default": "data/valid"
    },
    "out_dir": {
      "type": "string",
      "format": "directory",
      "default": "data/outputs"
    },
    "log_dir": {
      "type": "string",
      "format": "directory",
      "default": "data/outputs/logs"
    },

    "pacbio_fastq": {
      "type": ["string", "null"],
      "format": "file",
      "default": null
    },
    "nanopore_fastq": {
      "type": ["string", "null"],
      "format": "file",
      "default": null
    },
    "gff": {
      "type": ["string", "null"],
      "format": "file",
      "default": null
    },

    "max_cpu": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "contig_file_size": {
      "type": "integer",
      "minimum": 1
    },

    "clean_work": {
      "type": "boolean",
      "default": true
    },

    "run_truvari": {
      "type": "boolean",
      "default": false
    },
    "run_syri": {
      "type": "boolean",
      "default": false
    },
    "run_illumina": {
      "type": "boolean",
      "default": false
    },
    "run_nanopore": {
      "type": "boolean",
      "default": false
    },
    "run_pacbio": {
      "type": "boolean",
      "default": false
    },
    "run_vcf_annotation": {
      "type": "boolean",
      "default": false
    },

    "ref_fasta_validated": {
      "type": "string",
      "format": "file",
      "hidden": true
    },
    "mod_fasta_validated": {
      "type": "string",
      "format": "file",
      "hidden": true
    },
    "mod_fasta_avail": {
      "type": "boolean",
      "default": false,
      "hidden": true
    }
  }
}