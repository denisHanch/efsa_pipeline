nextflow.enable.dsl = 2

params {
  in_dir  = 'data/valid'
  out_dir = 'data/outputs'
  log_dir = 'data/outputs/logs'
  
  help = false
  max_cpu = 1
  clean_work = true

  ref_fasta_validated = null
  mod_fasta_validated = null
  ref_plasmid_fasta = null
  mod_plasmid_fasta = null
  gff = null
  illumina_fastqs = []
  ont_fastqs = []
  ont_bams = []
  pacbio_fastqs = []
  pacbio_bams = []
  contig_files = []
  validation_timestamp = ''
  run_ref_x_mod = false
  run_truvari = false
  run_illumina = false
  run_nanopore = false
  run_pacbio = false
  contig_file_size = 0
  run_vcf_annotation = false
}


process {

  errorStrategy = 'terminate'  // terminate|finish|ignore
  cpus  = 1
  memory = '8 GB'
  time  = '8h'


  withName: trimgalore {
    cpus = Math.min(params.max_cpu as int, 16)
    memory = '12 GB'
    time = '2h'
  }

  withName: bwa_mapping {
    cpus = Math.min(params.max_cpu as int, 24)
    memory = '24 GB'
    time = '12h'
  }

  withName: minimap2 {
    cpus = Math.min(params.max_cpu as int, 48)
    memory = '64 GB'
    time = '24h'
  }

  withName: samtools_sort {
    cpus = Math.min(params.max_cpu as int, 24)
    memory = '96 GB'
    time = '24h'
  }

  withName: get_unmapped_reads {
    cpus = Math.min(params.max_cpu as int, 16)
    memory = '32 GB'
    time = '8h'
  }

  withName: nanoplot {
    cpus = Math.min(params.max_cpu as int, 8)
    memory = '32 GB'
    time = '8h'
  }

  withName: cute_sv {
    cpus = Math.min(params.max_cpu as int, 48)
    memory = '64 GB'
    time = '24h'
  }

  withName: debreak {
    cpus = Math.min(params.max_cpu as int, 16)
    memory = '96 GB'
    time = '24h'
  }

  withName: sniffles {
    cpus = Math.min(params.max_cpu as int, 16)
    memory = '64 GB'
    time = '24h'
  }

  withName: freebayes {
    cpus = Math.min(params.max_cpu as int, 16)
    memory = '64 GB'
    time = '24h'
  }

  withName: mosdepth {
    cpus = Math.min(params.max_cpu as int, 8)
    memory = '16 GB'
    time = '8h'
  }

  withName: build_sv_flank_bed {
    cpus = 1
    memory = '2 GB'
    time = '1h'
  }

  withName: /^(build_config|snpeff)$/ {
    cpus = Math.min(params.max_cpu as int, 8)
    memory = '32 GB'
    time = '12h'
  }

  withName: multiqc {
    cpus = Math.min(params.max_cpu as int, 4)
    memory = '16 GB'
    time = '4h'
  }

  withName: bcftools_stats       { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: convert_bcf_to_vcf   { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: index_vcf            { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }  
  withName: sort_vcf             { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: bcftools_concat      { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: vcf_to_table_short   { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: vcf_to_table_asm     { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: vcf_to_table_long    { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: extract_supp_reads   { container = 'staphb/bcftools:1.23@sha256:22f4ddfd3f6e397f01cc21a7cf8338a1bb259d31680132b867c281041d8120d5' }
  withName: bgzip_tabix          { container = 'staphb/htslib:1.23@sha256:400e7c4e64a4a1c4698a21d58ba45796b884a555550e4dcc3b4e0482b0a928cc'   }
  withName: bwa_index            { container = 'biocontainers/bwa:v0.7.17_cv1@sha256:9479b73e108ded3c12cb88bb4e918a5bf720d7861d6d8cdbb46d78a972b6ff1b' }
  withName: bwa_mapping          { container = 'biocontainers/bwa:v0.7.17_cv1@sha256:9479b73e108ded3c12cb88bb4e918a5bf720d7861d6d8cdbb46d78a972b6ff1b' }
  withName: cute_sv              { container = 'ecomolegmo/cutesv:v1.0.4@sha256:9c29e67b576a13ef8839a2e11de8a62b7d6c5b86de5bdc037000c1c59de441c8' }
  withName: debreak              { container = 'ecomolegmo/debreak:v1.0.3@sha256:f2d8f9b5feccb483428558b2afe0cb1ade4689f815902438b3ba84416ed6fdb1' }
  withName: delly                { container = 'dellytools/delly:v1.7.3@sha256:045aba10409443a9b98953a93dab3f225110f37630ce81f44fe2fa3beb518567' }
  withName: fastqc               { container = 'biocontainers/fastqc:v0.11.9_cv8@sha256:82e5fa413d275a72c3de76e400a3d12a93ebdb4e1ef5391d7f7e9ce686671d8d' }
  withName: freebayes            { container = 'biocontainers/freebayes:v1.2.0-2-deb_cv1@sha256:1ce0e08e7def1ddc504de1a546c8b6dbb3932a9435894422c3401e9716c397f8' }
  withName: minimap2             { container = 'ecomolegmo/minimap2:v2.30@sha256:50d38b713d7d68e105aa3870950492407d82128aa9f3c7c20307632edcab50a5' }
  withName: mosdepth             { container = 'ecomolegmo/mosdepth:0.3.11@sha256:b24676b8dfff5cfa48e36e0a8a495261778d6aae710de3851823878fbdfde0e4' }
  withName: multiqc              { container = 'staphb/multiqc:1.33@sha256:4dbb26ba1acb31c6d662859c3bb1b680185e1b5b76d5b520ccb1f32b2d85c8dd' }
  withName: nucmer               { container = 'staphb/mummer:4.0.1@sha256:f41066448d8c6229a2806ee82396a2107cc69bf2997d2f361642821d96ec7ff6' }
  withName: delta_filter         { container = 'staphb/mummer:4.0.1@sha256:f41066448d8c6229a2806ee82396a2107cc69bf2997d2f361642821d96ec7ff6' }
  withName: show_coords          { container = 'staphb/mummer:4.0.1@sha256:f41066448d8c6229a2806ee82396a2107cc69bf2997d2f361642821d96ec7ff6' }
  withName: nanoplot             { container = 'staphb/nanoplot:1.46.2@sha256:824dbbe135ff5aa66b62c58864df2334adbbdfe2718a967569df4626ceb603e1' }
  withName: picard_dict          { container = 'broadinstitute/picard:3.4.0@sha256:dda3ad2638576fb9f2f8b336ba32f36fffca576ff2a5577b39da739746ce6b76' }
  withName: picard               { container = 'broadinstitute/picard:3.4.0@sha256:dda3ad2638576fb9f2f8b336ba32f36fffca576ff2a5577b39da739746ce6b76' }
  withName: samtools_index       { container = 'staphb/samtools:1.23@sha256:ed3785374d84fff0fe41243984d163d67feba3785ef573bdbaab54aae3d9acf8' }
  withName: samtools_index_bam   { container = 'staphb/samtools:1.23@sha256:ed3785374d84fff0fe41243984d163d67feba3785ef573bdbaab54aae3d9acf8' }
  withName: samtools_sort        { container = 'staphb/samtools:1.23@sha256:ed3785374d84fff0fe41243984d163d67feba3785ef573bdbaab54aae3d9acf8' }
  withName: samtools_stats       { container = 'staphb/samtools:1.23@sha256:ed3785374d84fff0fe41243984d163d67feba3785ef573bdbaab54aae3d9acf8' }
  withName: get_unmapped_reads   { container = 'staphb/samtools:1.23@sha256:ed3785374d84fff0fe41243984d163d67feba3785ef573bdbaab54aae3d9acf8' }
  withName: calc_total_reads     { container = 'staphb/samtools:1.23@sha256:ed3785374d84fff0fe41243984d163d67feba3785ef573bdbaab54aae3d9acf8' }
  withName: sniffles             { container = 'ecomolegmo/sniffles:v1.0.3@sha256:d3875e4e183afb06d1f1e11bd122de39f9a5ec4e9f2c46750a42e33dd2454fb1' }
  withName: snpeff               { container = 'biocontainers/snpeff:v4.1k_cv3@sha256:200e81221e5aa964c8988691d8f85351a394cb0b96eac13b3cc4593155fc0297' }
  withName: build_config         { container = 'biocontainers/snpeff:v4.1k_cv3@sha256:200e81221e5aa964c8988691d8f85351a394cb0b96eac13b3cc4593155fc0297' }
  withName: survivor             { container = 'ecomolegmo/survivor:v1.0.3@sha256:90263d6becc2526eaad168c54ccb3a240add5624ae16c21fe01d53f8d64a9ad9' }
  withName: syri                 { container = 'ecomolegmo/syri:v1.0.4@sha256:789d5cdf96f4bbe6fc5dcfd3cf2830a89d8ec844c213376d41444237b7eafb25' }
  withName: trimgalore           { container = 'ecomolegmo/trimgalore:v1.0.1@sha256:802cc917eccec0d8d59ca0351120717b240477c45a67fdc4a5adb7664c3ea39d' }
  withName: truvari              { container = 'ecomolegmo/truvari:v1.0.3@sha256:ae346a3bae0c7011dc6708e288dc1e8e1c37776ef24a39075241d6ef0b98ebac' }
}

manifest {
    name             = 'denisHanch/efsa_pipeline'
    description      = 'A pipeline that processes prokaryotic long & short reads using Nextflow'
    version          = '1.0.0'
    nextflowVersion  = '25.10.4'
    homePage         = 'https://github.com/denisHanch/efsa_pipeline'
    license          = 'EUPL-1.2'
    mainScript       = 'main.nf'
}

docker {
  enabled    = true
  runOptions = '-u $(id -u):$(id -g)'
}

profiles {
  standard {
  }
  test {
      params.max_cpu = 1
      process {
          cpus = 1
          memory = '2 GB'
          time = '1h'
          withName: /.*/ {
              cpus = 1
              memory = '2 GB'
              time = '1h'
          }
      }
  }
}

trace {
    enabled   = true
    overwrite = true
    file      = 'data/outputs/logs/trace.tsv'
    fields    = 'task_id,name,status,exit,start,complete,duration,realtime,cpus,%cpu,memory,%mem,rss,peak_rss,vmem,peak_vmem,read_bytes,write_bytes,attempt'
}

report {
    enabled = true
    overwrite = true
    file = 'data/outputs/logs/report.html'
}

timeline {
    enabled = true
    overwrite = true
    file = 'data/outputs/logs/timeline.html'
}